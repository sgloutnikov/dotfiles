#################
# ENV VARIABLES #
#################

# History
HISTSIZE=10000
SAVEHIST=50000

# Homebrew
export HOMEBREW_NO_INSTALL_CLEANUP=1

# Default editor
export EDITOR=nvim

# Go
export GOPATH="$HOME/go"
export GOBIN="$HOME/go/bin"
export PATH=$PATH:$GOBIN

# Python
export PATH="/opt/homebrew/opt/python@3.10/bin:$PATH"

# Kubernetes
# Krew
export PATH="${KREW_ROOT:-$HOME/.krew}/bin:$PATH"


